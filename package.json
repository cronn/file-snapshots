{
  "name": "root",
  "private": true,
  "homepage": "https://github.com/cronn/file-snapshots",
  "license": "Apache-2.0",
  "author": "cronn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cronn/file-snapshots.git"
  },
  "type": "module",
  "scripts": {
    "clean": "rimraf .turbo && pnpm run pnpm:clean",
    "compile": "tsc",
    "config:check": "meta-updater --test",
    "config:fix": "meta-updater",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "knip:check": "knip",
    "knip:fix": "knip --fix",
    "pnpm:check": "pnpm dedupe --check",
    "pnpm:clean": "pnpm pm clean",
    "pnpm:fix": "pnpm dedupe",
    "prepublishOnly": "pnpm turbo run ci",
    "release": "pnpm turbo run build && pnpm publish --recursive --access=public --provenance && pnpm changeset tag",
    "version": "pnpm changeset version && pnpm turbo run format:fix"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@cronn/meta-updater": "workspace:*",
    "@pnpm/meta-updater": "catalog:",
    "@typescript/native": "catalog:",
    "knip": "catalog:",
    "oxfmt": "catalog:",
    "rimraf": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.1",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": "^22 || ^24 || >=26"
  }
}

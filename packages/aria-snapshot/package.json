{
  "name": "@cronn/aria-snapshot",
  "version": "1.0.1",
  "description": "JSON-based ARIA snapshots for Playwright",
  "homepage": "https://cronn.github.io/file-snapshots/playwright/aria-snapshots",
  "bugs": {
    "url": "https://github.com/cronn/file-snapshots/issues"
  },
  "license": "Apache-2.0",
  "author": "cronn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cronn/file-snapshots.git",
    "directory": "packages/aria-snapshot"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf .turbo dist playwright-report test-results coverage",
    "compile": "tsgo",
    "lint:check": "eslint src/ tests/ --max-warnings=0",
    "lint:fix": "eslint src/ tests/ --max-warnings=0 --fix",
    "playwright:install": "playwright install chromium",
    "test:integration": "playwright test",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@cronn/playwright-file-snapshots": "workspace:*",
    "@cronn/shared-configs": "workspace:*",
    "@cronn/test-utils": "workspace:*",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-check-file": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@playwright/test": "^1.55"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11 <12",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.14.1 <25",
      "onFail": "error"
    }
  },
  "engines": {
    "node": "^20 || ^22 || >=24"
  },
  "packageManager": "pnpm@11.0.1"
}

{
  "name": "@cronn/lib-file-snapshots",
  "version": "1.1.1",
  "description": "The library agnostic core for testing file snapshots",
  "keywords": [
    "file snapshots"
  ],
  "homepage": "https://github.com/cronn/file-snapshots",
  "bugs": {
    "url": "https://github.com/cronn/file-snapshots/issues"
  },
  "license": "Apache-2.0",
  "author": "cronn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cronn/file-snapshots.git",
    "directory": "packages/lib-file-snapshots"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf .turbo dist coverage",
    "compile": "tsgo",
    "lint:check": "eslint src/ --max-warnings=0",
    "lint:fix": "eslint src/ --max-warnings=0 --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "markdown-table": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@cronn/shared-configs": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-check-file": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.4 <12",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.14.1 <25",
      "onFail": "error"
    }
  },
  "engines": {
    "node": "^20 || ^22 || >=24"
  },
  "packageManager": "pnpm@11.0.4"
}

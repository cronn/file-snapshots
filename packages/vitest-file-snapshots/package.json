{
  "name": "@cronn/vitest-file-snapshots",
  "version": "1.1.2",
  "description": "Write tests with Vitest using file snapshots",
  "keywords": [
    "vitest",
    "file snapshots"
  ],
  "bugs": {
    "url": "https://github.com/cronn/file-snapshots/issues"
  },
  "author": "cronn",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cronn/file-snapshots.git",
    "directory": "packages/vitest-file-snapshots"
  },
  "homepage": "https://cronn.github.io/file-snapshots/vitest/",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^20 || ^22 || >=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.14.1 <25",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=10.33.0 <11",
      "onFail": "error"
    }
  },
  "scripts": {
    "lint:check": "eslint src/ --max-warnings=0",
    "lint:fix": "eslint src/ --max-warnings=0 --fix",
    "test:core": "vitest run --tags-filter=!update-*",
    "test:update-new": "vitest run --tags-filter=update-new --update new",
    "test:update-all": "vitest run --tags-filter=update-all --update all",
    "test:update-none": "vitest run --tags-filter=update-none --update none",
    "test:coverage": "vitest run --tags-filter=!update-* --coverage",
    "compile": "tsgo",
    "build": "tsdown && node scripts/fix-declaration-file.ts",
    "clean": "rimraf .turbo dist coverage"
  },
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./register": {
      "types": "./dist/register.d.mts",
      "default": "./dist/register.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@cronn/lib-file-snapshots": "workspace:*"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@cronn/shared-configs": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/expect": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-check-file": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "package-directory": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "vitest": "^4.1.4"
  }
}

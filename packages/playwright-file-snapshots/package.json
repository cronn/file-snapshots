{
  "name": "@cronn/playwright-file-snapshots",
  "version": "1.0.5",
  "description": "Write tests with Playwright using file snapshots",
  "keywords": [
    "file snapshots",
    "playwright"
  ],
  "homepage": "https://cronn.github.io/file-snapshots/playwright/",
  "bugs": {
    "url": "https://github.com/cronn/file-snapshots/issues"
  },
  "license": "Apache-2.0",
  "author": "cronn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cronn/file-snapshots.git",
    "directory": "packages/playwright-file-snapshots"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf .turbo dist playwright-report test-results coverage",
    "compile": "tsgo",
    "lint:check": "eslint src/ tests/ --max-warnings=0",
    "lint:fix": "eslint src/ tests/ --max-warnings=0 --fix",
    "playwright:install": "playwright install chromium",
    "test:integration:core": "playwright test",
    "test:integration:update-all": "playwright test --grep @update-all --update-snapshots all",
    "test:integration:update-changed": "playwright test --grep @update-changed --update-snapshots changed",
    "test:integration:update-none": "playwright test --grep @update-none --update-snapshots none",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cronn/lib-file-snapshots": "workspace:*",
    "package-directory": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@cronn/shared-configs": "workspace:*",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-check-file": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@playwright/test": "^1.55"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11 <12",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.14.1 <25",
      "onFail": "download"
    }
  },
  "engines": {
    "node": "^20 || ^22 || >=24"
  },
  "packageManager": "pnpm@11.0.1"
}

{
  "name": "@cronn/test-utils",
  "version": "0.0.0",
  "private": true,
  "description": "Internal test utils for the monorepo",
  "homepage": "https://github.com/cronn/file-snapshots",
  "license": "Apache-2.0",
  "author": "cronn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cronn/file-snapshots.git",
    "directory": "packages/test-utils"
  },
  "type": "module",
  "exports": {
    "./playwright": {
      "types": "./dist/playwright.d.mts",
      "default": "./dist/playwright.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf .turbo dist",
    "compile": "tsgo",
    "lint:check": "eslint src/ --max-warnings=0",
    "lint:fix": "eslint src/ --max-warnings=0 --fix"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@cronn/shared-configs": "workspace:*",
    "@playwright/test": "catalog:",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-check-file": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11 <12",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.14.1 <25",
      "onFail": "download"
    }
  },
  "engines": {
    "node": "^20 || ^22 || >=24"
  },
  "packageManager": "pnpm@11.0.1"
}

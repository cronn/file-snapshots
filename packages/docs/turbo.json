{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "dev": {
      "persistent": true,
      "dependsOn": ["compile"],
      "outputs": [".vitepress/cache/**"],
      "outputLogs": "new-only"
    },
    "build": {
      "outputs": [".vitepress/dist/**"]
    },
    "preview": {
      "persistent": true,
      "dependsOn": ["build"],
      "outputLogs": "new-only"
    }
  }
}
